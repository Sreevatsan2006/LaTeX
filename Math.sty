% Generic color callout:
%   \begin{ColorNoteBox}{<ColorName>}[Optional Title] ... \end{ColorNoteBox}
% This is useful when a semantic box is not specific enough.
% `<ColorName>` must be an xcolor-known color.
\NewDocumentEnvironment{ColorNoteBox}{m O{} +b}{%
  \begin{mdframed}[
    linecolor=#1,
    linewidth=\Math@CalloutLineWidth,
    backgroundcolor=#1!\Math@GenericBoxTint,
    roundcorner=4pt,
    innertopmargin=0.45em,
    innerbottommargin=0.45em,
    innerleftmargin=0.65em,
    innerrightmargin=0.65em,
    skipabove=0.35em,
    skipbelow=0.35em,
    nobreak=true
  ]\Math@BoxTitle{#2}#3\end{mdframed}%
}{}

% Simple all-purpose colored box:
% Usage:
%   \begin{generalbox}[Blue][Optional Title] ... \end{generalbox}
% First optional argument = border/fill base color.
% Second optional argument = title line (leave empty for no title).
\NewDocumentEnvironment{generalbox}{O{Blue} O{} +b}{%
  \begin{ColorNoteBox}{#1}[#2]#3\end{ColorNoteBox}%
}{}

% Readable alias (PascalCase). We avoid lowercase `box`/`colorbox` because
% those names collide with core TeX/xcolor commands.
\ifcsdef{ColorBox}{%
  \RenewDocumentEnvironment{ColorBox}{O{Blue} O{} +b}{%
    \begin{generalbox}[#1][#2]#3\end{generalbox}%
  }{}%
}{%
  \NewDocumentEnvironment{ColorBox}{O{Blue} O{} +b}{%
    \begin{generalbox}[#1][#2]#3\end{generalbox}%
  }{}%
}

% Exact all-caps alias for users who prefer uppercase environment names.
\ifcsdef{COLORBOX}{%
  \RenewDocumentEnvironment{COLORBOX}{O{Blue} O{} +b}{%
    \begin{ColorBox}[#1][#2]#3\end{ColorBox}%
  }{}%
}{%
  \NewDocumentEnvironment{COLORBOX}{O{Blue} O{} +b}{%
    \begin{ColorBox}[#1][#2]#3\end{ColorBox}%
  }{}%
}

% Short alias for fast note-taking.
\NewDocumentEnvironment{gbox}{O{Blue} O{} +b}{%
