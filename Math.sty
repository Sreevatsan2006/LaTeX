% Apply frame definitions once at load time.
\Math@DefineFramedStyles

% Public color API
\NewDocumentCommand{\MathColorMode}{m}{%
  \edef\Math@requestedmode{#1}%
  \ifdefstring{\Math@requestedmode}{none}{%
    \def\Math@colormode{none}%
  }{%
    \ifdefstring{\Math@requestedmode}{minimal}{%
      \def\Math@colormode{minimal}%
    }{%
      \ifdefstring{\Math@requestedmode}{balanced}{%
        \def\Math@colormode{balanced}%
      }{%
        \ifdefstring{\Math@requestedmode}{rich}{%
          \def\Math@colormode{rich}%
        }{%
          \PackageWarning{Math}{Unknown color mode '#1'. Falling back to balanced}%
          \def\Math@colormode{balanced}%
        }%
      }%
    }%
  }%
  % Recompute color variables, hyperlink colors, and frame styles together.
  \Math@ApplyColorModeSettings
  \Math@ApplyLinkColors
  \Math@DefineFramedStyles
}

% Helper for optional box titles:
% prints a bold heading only when a non-empty title is supplied.
\providecommand{\Math@BoxTitle}[1]{%
  \ifstrempty{#1}{}{{\textbf{\textcolor{Ink}{#1}}\par\smallskip}}%
}

% Semantic callout environments (all share the same interface):
%   \begin{<name>}[Optional Title] ... \end{<name>}
% Examples: infobox, successbox, warningbox, dangerbox, ideabox, ...
\NewDocumentEnvironment{infobox}{O{} +b}{%
  \begin{mdframed}[style=infoboxstyle]\Math@BoxTitle{#1}#2\end{mdframed}%
}{}

\NewDocumentEnvironment{successbox}{O{} +b}{%
