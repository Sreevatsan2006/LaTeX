  }%
}

% Lightweight algorithm wrapper (no algorithm/algpseudocode dependency).
% - `pseudocode` prints a titled framed block in monospaced text.
% - `algo` is a short alias with identical behavior.
% - No forced numbering, no forced keywords: write natural-language pseudocode.
\NewDocumentEnvironment{pseudocode}{O{Algorithm} +b}{%
  \begin{mdframed}[style=algoboxstyle]%
  {\textbf{\textcolor{\Math@AlgoTitleColor}{#1}}}\par\smallskip
  {\ttfamily\small #2}%
  \end{mdframed}%
}{}

\NewDocumentEnvironment{algo}{O{Algorithm} +b}{%
  \begin{pseudocode}[#1]#2\end{pseudocode}%
}{}

