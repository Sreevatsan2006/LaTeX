% ------------------------------------------------------------------------------
% 1) HOW TO USE
% ------------------------------------------------------------------------------

%   What this package is for:
% - You add one \usepackage line, and a standard math document instantly gets
%   better defaults: cleaner typography, theorem framing, callouts, useful
%   macros, and better hyperlink styling.
% - It is built to work with normal AMS-style writing, but it is not limited to
%   one class. It is suitable for article/report/book class workflows.
%

% Put this in your preamble:
%
%   \usepackage[palatino]{Math}
%
% That is enough to start.
%
% Available font options:
%   \usepackage[classic]{Math}   % Computer Modern
%   \usepackage[charter]{Math}   % Charter
%   \usepackage[palatino]{Math}  % Palatino (default)
%
% ------------------------------------------------------------------------------
% 2) WHAT MATH.STY ALREADY LOADS FOR YOU
% ------------------------------------------------------------------------------
%
% This package already loads core tools:
% - amsmath, amssymb, amsthm, mathtools
% - hyperref + cleveref for references
% - xcolor, geometry, enumitem, fancyhdr, mdframed, microtype
% - graphicx, float, booktabs, tabularx, array, multirow
% - bm, bbm for bold symbols / indicator notation
%
% - Since this is intended as a one-shot default package, avoid re-importing
%   the same packages in each document unless you need special options.
% - If your existing file already loads some of these, duplicates are usually
%   harmless but unnecessary. 
%
% ------------------------------------------------------------------------------
% 3) COLOR MODE (HOW MUCH VISUAL STYLING YOU WANT)
% ------------------------------------------------------------------------------
%
% Choose one mode after loading the package:
%
%   \MathColorMode{none}      % plain look, no visible framing accents
%   \MathColorMode{minimal}   % very light accents
%   \MathColorMode{balanced}  % default, moderate structure cues
%   \MathColorMode{rich}      % strongest visual accents
%
% If you only want fonts/spacing/macros with almost no visual chrome, use:
%   \MathColorMode{none}
%
% ------------------------------------------------------------------------------
% 4) DROP-IN COMPATIBILITY WITH EXISTING FILES
% ------------------------------------------------------------------------------
%
% Theorem environments in this package are defined conditionally.
% Meaning:
% - If your file ALREADY defines `theorem` (or lemma/definition/etc), Math.sty
%   will not redefine that environment.
% - If an environment is missing, Math.sty provides it.
%
% This lets old files keep their custom theorem setup while new files get defaults automatically.
%
% ==============================================================================
% General-purpose template for mathematical writing.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{Math}


% Package options

% `notikz`:
%   Do not load TikZ. Useful for faster compiles if you are not drawing figures.
\newif\ifMath@tikz
\Math@tikztrue
\DeclareOption{notikz}{\Math@tikzfalse}

% `standardsections`:
% Keep default LaTeX behavior for starred sections/subsections.
% Without this option, starred section commands are promoted to numbered sections and are inserted into the table of contents.
\newif\ifMath@standardsections
\Math@standardsectionsfalse
\DeclareOption{standardsections}{\Math@standardsectionstrue}

% Font options
% `classic`  -> default Computer Modern text look
% `charter`  -> Charter text
% `palatino` -> Palatino text (default)
\def\Math@font{palatino}
\DeclareOption{classic}{\def\Math@font{classic}}
\DeclareOption{charter}{\def\Math@font{charter}}
\DeclareOption{palatino}{\def\Math@font{palatino}}


\ProcessOptions\relax

% Core packages
% This block is intentionally broad so Math.sty can be used as a one-shot
% default import for common mathematical writing workflows.
\RequirePackage{amsmath,amssymb,amsthm}
\RequirePackage{mathtools}
\RequirePackage{xcolor}
\RequirePackage[expansion=false]{microtype}
\RequirePackage[a4paper,margin=1in]{geometry}
\RequirePackage{graphicx}
\RequirePackage{array}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{multirow}
\RequirePackage{float}
\RequirePackage{bm}
\RequirePackage{bbm}
\RequirePackage{etoolbox}
\RequirePackage{mdframed}
\RequirePackage{hyperref}
\RequirePackage[nameinlink,noabbrev]{cleveref}
\RequirePackage{xparse}
\RequirePackage{needspace}
\RequirePackage[shortlabels]{enumitem}
\RequirePackage{fancyhdr}

% Font selection
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\ifdefstring{\Math@font}{classic}{}{%
  \ifdefstring{\Math@font}{charter}{%
    \RequirePackage{charter}%
  }{%
    \RequirePackage{mathpazo}%
  }%
}

% Global text flow defaults:

% Line spacing slightly increased increase for better readability
\linespread{1.03}
% Paragraphs without indentation
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.35em}
% Emergency stretch to reduce overfull lines.
\setlength{\emergencystretch}{2em}


% TikZ integration:
% 1) By default, TikZ is ON in this template, so diagrams work immediately.
% 2) If a document does not need figures, the user can load:
%    \usepackage[notikz]{Math}
%    which flips \ifMath@tikz to false and skips this block.
% 3) Skipping TikZ can noticeably speed up compile time in text-heavy notes.
% 4) The `positioning` library is loaded so node placement like
%      right=of A, below=of B
%    works out of the box without extra user configuration.
\ifMath@tikz
  \RequirePackage{tikz}
  \usetikzlibrary{positioning}
\fi

