\NewDocumentCommand{\DefineNoteBoxStyle}{mm}{%
  \mdfdefinestyle{#1}{%
    linecolor=#2,
    linewidth=\Math@CalloutLineWidth,
    backgroundcolor=#2!\Math@GenericBoxTint,
    roundcorner=4pt,
    innertopmargin=0.45em,
