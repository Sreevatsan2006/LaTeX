% ------------------------------------------------------------------
% Color mode engine (user-facing customization layer)
% ------------------------------------------------------------------
% What this block controls:
% 1) Frame intensity (line widths + background tinting),
% 2) Heading accent colors (theorem/definition/etc. titles),
% 3) Inline emphasis colors (\key, \warn, \result),
% 4) Link colors (internal/external/citation links).
%
% Supported modes: none, minimal, balanced (default), rich.
% - none: keep typography/layout, remove visible framing and color accents.
% - minimal: light visual styling.
% - balanced: moderate/default styling.
% - rich: strongest styling while staying structured.
%
% Quick user usage in a .tex file:
%   \MathColorMode{none}
%
% Maintainer note:
% - If you add a new mode, update BOTH:
%   1) \Math@ApplyColorModeSettings (behavior),
%   2) \MathColorMode command (mode parser below).
\def\Math@colormode{balanced}
% Framed-block appearance knobs:
% - \Math@CalloutBgMix: background blend strength (0 = white, 100 = full color)
% - \Math@GenericBoxTint: tint level used by generic/custom color boxes
% - \Math@MainLineWidth: line width for theorem/major framed blocks
% - \Math@CalloutLineWidth: line width for lightweight callout boxes
\def\Math@CalloutBgMix{100}
\def\Math@GenericBoxTint{9}
\def\Math@MainLineWidth{0.9pt}
\def\Math@CalloutLineWidth{0.9pt}
% Heading + inline emphasis colors. These are reassigned per mode.
\def\Math@TheoremHeadColor{Blue}
\def\Math@StatementHeadColor{Violet}
\def\Math@DefinitionHeadColor{Orange}
\def\Math@AlgoTitleColor{Violet}
\def\Math@KeyColor{Cobalt}
\def\Math@WarnColor{Red}
\def\Math@ResultColor{Gold}
\def\Math@ResultBgColor{HighlightBg}



\providecommand{\Math@ApplyColorModeSettings}{%
  % Base palette for non-none modes.
  \def\Math@TheoremHeadColor{Blue}%
  \def\Math@StatementHeadColor{Violet}%
  \def\Math@DefinitionHeadColor{Orange}%
  \def\Math@AlgoTitleColor{Violet}%
  \def\Math@KeyColor{Cobalt}%
  \def\Math@WarnColor{Red}%
  \def\Math@ResultColor{Gold}%
  \def\Math@ResultBgColor{HighlightBg}%



  \ifdefstring{\Math@colormode}{none}{%
    % "none" = remove colors but keep spacing/layout stable.
    \def\Math@CalloutBgMix{0}%
    \def\Math@GenericBoxTint{0}%
    \def\Math@MainLineWidth{0pt}%
    \def\Math@CalloutLineWidth{0pt}%
    \def\Math@TheoremHeadColor{Ink}%
    \def\Math@StatementHeadColor{Ink}%
    \def\Math@DefinitionHeadColor{Ink}%
    \def\Math@AlgoTitleColor{Ink}%
    \def\Math@KeyColor{Ink}%
    \def\Math@WarnColor{Ink}%
    \def\Math@ResultColor{Ink}%
    \def\Math@ResultBgColor{white}%
  }{%
    \ifdefstring{\Math@colormode}{minimal}{%
      % Minimal mode: subtle frame + light background tint.
      \def\Math@CalloutBgMix{88}%
      \def\Math@GenericBoxTint{7}%
      \def\Math@MainLineWidth{0.75pt}%
      \def\Math@CalloutLineWidth{0.75pt}%
    }{%
      \ifdefstring{\Math@colormode}{rich}{%
        % Rich mode: strongest line/tint settings.
        \def\Math@CalloutBgMix{100}%
        \def\Math@GenericBoxTint{13}%
        \def\Math@MainLineWidth{1.1pt}%
        \def\Math@CalloutLineWidth{1.0pt}%
      }{%
        % Balanced mode (default)
        \def\Math@CalloutBgMix{100}%
        \def\Math@GenericBoxTint{9}%
        \def\Math@MainLineWidth{0.9pt}%
        \def\Math@CalloutLineWidth{0.9pt}%
      }%
    }%
  }%
}

\providecommand{\Math@ApplyLinkColors}{%
  % Link colors are kept separate so they can be changed individually.
  % - linkcolor: internal refs (\ref, \cref, table/figure refs)
  % - urlcolor : external URLs
  % - citecolor: bibliography citations
  \hypersetup{%
    linkcolor=Indigo,
    urlcolor=Violet,
    citecolor=Violet,
    filecolor=Violet,
    anchorcolor=Indigo
  }%
}




% Package startup styling.
% 1) Read the current color mode (none/minimal/balanced/rich) and apply all
%    style values (box lines, heading colors, fills, emphasis colors).
% 2) Keep hyperlink text colored instead of boxed.
% 3) Apply the internal/external/citation link colors defined above.
% Users can always override link behavior in the document preamble, e.g.
%   \hypersetup{colorlinks=false}
\Math@ApplyColorModeSettings
\hypersetup{colorlinks=true}
\Math@ApplyLinkColors

% List spacing defaults.
% Goal: readable lists that do not waste vertical space.
% - leftmargin=*  : align list body naturally with surrounding text width.
% - itemsep       : spacing between consecutive items.
% - topsep        : spacing above and below the list block.
% You can override these in your .tex file with your own \setlist calls.
\setlist[itemize]{leftmargin=*, itemsep=0.15em, topsep=0.35em}
\setlist[enumerate]{leftmargin=*, itemsep=0.15em, topsep=0.35em}

% Running header/footer defaults.
% - Left header: current section title (\leftmark), preserving mixed case.
% - Right header: current page number.
% - Rule: thin separator under the header.
% - \sectionmark: updates \leftmark whenever a section starts.
% If you prefer plain pages, set \pagestyle{plain} in your main .tex.
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\nouppercase{\leftmark}}
\fancyhead[R]{\thepage}
\providecommand{\headrulewidth}{0.4pt}
\providecommand{\sectionmark}[1]{\markboth{#1}{}}

% Theorem heading styles.
% These style names are intentionally descriptive (PascalCase) so users can
% quickly understand what they control and switch styles safely.
%
% \newtheoremstyle arguments in order:
% 1) Space above, 2) Space below, 3) Body font, 4) Indent,
% 5) Head font, 6) Punctuation after head, 7) Space after head, 8) Head spec.
%
% `TheoremHeader`: core result statements.
%   Used for theorem / lemma / proposition / corollary.
% `SupportHeader`: supporting statement-like results.
%   Used for fact / property / conjecture / question / statement / observation.
% `DefinitionHeader`: definition-style statements.
% Examples/remarks intentionally use built-in amsthm styles (no custom header).
\newtheoremstyle{TheoremHeader}
  {0.6em}{0.6em}{}{}{\bfseries\color{\Math@TheoremHeadColor}}{.}{0.6em}{}
\newtheoremstyle{SupportHeader}
  {0.6em}{0.6em}{}{}{\bfseries\color{\Math@StatementHeadColor}}{.}{0.6em}{}
\newtheoremstyle{DefinitionHeader}
  {0.6em}{0.6em}{}{}{\bfseries\color{\Math@DefinitionHeadColor}}{.}{0.6em}{}

% Theorem-family numbering map with collision-safe declarations.
%
% Goal:
% - If a document already defines an environment (for example `theorem`),
%   Math.sty will not redefine it.
% - Missing environments are added automatically.
%
% This behavior enables seamless drop-in usage on legacy files while still
% giving sensible defaults on fresh files.
\providecommand{\Math@MaybeNewTheoremBySection}[3]{%
  \ifcsdef{#1}{}{%
    \theoremstyle{#2}%
    \newtheorem{#1}{#3}[section]%
  }%
}
\providecommand{\Math@MaybeNewTheoremShared}[4]{%
  \ifcsdef{#1}{}{%
    \theoremstyle{#2}%
    \newtheorem{#1}[#3]{#4}%
  }%
}

% Core theorem family.
% - `theorem` resets by section.
% - lemma/proposition/corollary share theorem numbering.
\Math@MaybeNewTheoremBySection{theorem}{TheoremHeader}{Theorem}
\Math@MaybeNewTheoremShared{lemma}{TheoremHeader}{theorem}{Lemma}
\Math@MaybeNewTheoremShared{proposition}{TheoremHeader}{theorem}{Proposition}
\Math@MaybeNewTheoremShared{corollary}{TheoremHeader}{theorem}{Corollary}

% Support statement family.
% - `fact` resets by section.
% - related statement environments share `fact` numbering.
\Math@MaybeNewTheoremBySection{fact}{SupportHeader}{Fact}
\Math@MaybeNewTheoremShared{property}{SupportHeader}{fact}{Property}
\Math@MaybeNewTheoremShared{conjecture}{SupportHeader}{fact}{Conjecture}
\Math@MaybeNewTheoremShared{question}{SupportHeader}{fact}{Question}
\Math@MaybeNewTheoremShared{statement}{SupportHeader}{fact}{Statement}
\Math@MaybeNewTheoremShared{obs}{SupportHeader}{fact}{Observation}

% Definitions/examples/remarks keep independent section-based counters.
\Math@MaybeNewTheoremBySection{definition}{DefinitionHeader}{Definition}
\Math@MaybeNewTheoremBySection{example}{definition}{Example}
\Math@MaybeNewTheoremBySection{remark}{remark}{Remark}




% ------------------------------
% Framed Box Engine
% ------------------------------
% This section defines all `mdframed` styles used by theorem wrappers and user-facing callouts.
%
% Naming convention:
% - `theorembox`, `definitionbox`, ... : larger blocks used around theorem-like
%   environments.
% - `...boxstyle`                       : reusable callout styles for custom
%   box environments (info/success/warning/etc).
%
% Internal helper:
%   \Math@DefineUnframedStyle{style}{skipAbove}{skipBelow}{innerVertical}{innerHorizontal}
% Used by color mode `none` so layout spacing remains stable while visible
% border/fill is removed.
\providecommand{\Math@DefineUnframedStyle}[5]{%
  \mdfdefinestyle{#1}{%
    linecolor=white,
    linewidth=0pt,
    backgroundcolor=white,
    roundcorner=0pt,
    innertopmargin=#4,
    innerbottommargin=#4,
    innerleftmargin=#5,
    innerrightmargin=#5,
    skipabove=#2,
    skipbelow=#3,
    nobreak=true
  }%
}

% Rebuild every frame style according to the active color mode.
% This runs at package load and whenever \MathColorMode{...} is called.
\providecommand{\Math@DefineFramedStyles}{%
  \ifdefstring{\Math@colormode}{none}{%
    % "none" mode: preserve spacing footprint but remove visible chrome.
    \Math@DefineUnframedStyle{theorembox}{0.8em}{0.8em}{0.7em}{0.9em}%
    \Math@DefineUnframedStyle{definitionbox}{0.8em}{0.8em}{0.7em}{0.9em}%
    \Math@DefineUnframedStyle{supportboxstyle}{0.8em}{0.8em}{0.7em}{0.9em}%
    \Math@DefineUnframedStyle{propertyboxstyle}{0.8em}{0.8em}{0.7em}{0.9em}%
    \Math@DefineUnframedStyle{infoboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{successboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{warningboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{dangerboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{ideaboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{exampleboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{hintboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{blueboxstyle}{0.35em}{0.35em}{0.45em}{0.65em}%
    \Math@DefineUnframedStyle{algoboxstyle}{0.7em}{0.7em}{0.6em}{0.8em}%
  }{%
    % Core theorem-family wrappers.
    \mdfdefinestyle{theorembox}{%
      linecolor=Blue,
      linewidth=\Math@MainLineWidth,
      backgroundcolor=InfoBg!\Math@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.7em,
      innerbottommargin=0.7em,
      innerleftmargin=0.9em,
      innerrightmargin=0.9em,
      skipabove=0.8em,
      skipbelow=0.8em,
      nobreak=true
    }%
    \mdfdefinestyle{definitionbox}{%
      linecolor=Orange,
      linewidth=\Math@MainLineWidth,
      backgroundcolor=WarningBg!\Math@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.7em,
      innerbottommargin=0.7em,
      innerleftmargin=0.9em,
      innerrightmargin=0.9em,
      skipabove=0.8em,
      skipbelow=0.8em,
      nobreak=true
    }%
    \mdfdefinestyle{supportboxstyle}{%
      linecolor=Violet,
      linewidth=\Math@MainLineWidth,
      backgroundcolor=HighlightBg!\Math@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.7em,
      innerbottommargin=0.7em,
      innerleftmargin=0.9em,
      innerrightmargin=0.9em,
      skipabove=0.8em,
      skipbelow=0.8em,
      nobreak=true
    }%
    % Property block intentionally a bit lighter than main theorem boxes.
    \mdfdefinestyle{propertyboxstyle}{%
      linecolor=Navy,
      linewidth=0.75pt,
      backgroundcolor=HighlightBg!\Math@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.7em,
      innerbottommargin=0.7em,
      innerleftmargin=0.9em,
      innerrightmargin=0.9em,
      skipabove=0.8em,
      skipbelow=0.8em,
      nobreak=true
    }%
    % Lightweight semantic callouts for notes and annotations.
    \mdfdefinestyle{infoboxstyle}{%
      linecolor=Cobalt,
      linewidth=\Math@CalloutLineWidth,
      backgroundcolor=InfoBg!\Math@CalloutBgMix,
      roundcorner=4pt,
      innertopmargin=0.45em,
      innerbottommargin=0.45em,
      innerleftmargin=0.65em,
      innerrightmargin=0.65em,
      skipabove=0.35em,
      skipbelow=0.35em,
      nobreak=true
    }%
    \mdfdefinestyle{successboxstyle}{%
      linecolor=Green,
      linewidth=\Math@CalloutLineWidth,
      backgroundcolor=SuccessBg!\Math@CalloutBgMix,
      roundcorner=4pt,
      innertopmargin=0.45em,
