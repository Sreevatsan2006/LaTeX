% ------------------------------
% Layout Defaults (Optional Subsystem)
% ------------------------------
% Purpose:
% - Apply assignment-friendly typography and spacing defaults.
%
% How to use:
% - Default behavior applies these settings automatically.
% - Disable with package option: \usepackage[nolayout]{Assignment}
%
% Public commands touched:
% - none (this block applies side-effect defaults only)
%
% Compatibility notes:
% - Disabling layout preserves macro/theorem subsystems.
\ifAssignment@layout
  \linespread{1.03}
  \setlength{\parindent}{0pt}
  \setlength{\parskip}{0.35em}
  \setlength{\emergencystretch}{2em}
\fi

\pgfplotsset{compat=1.18}
\algrenewcommand\algorithmiccomment[1]{\hfill{\footnotesize$\triangleright$ #1}}


% TikZ integration:
% 1) By default, TikZ is ON in this template, so diagrams work immediately.
% 2) If a document does not need figures, the user can load:
%    \usepackage[notikz]{Assignment}
%    which flips \ifAssignment@tikz to false and skips this block.
% 3) Skipping TikZ can noticeably speed up compile time in text-heavy notes.
% 4) The `positioning` library is loaded so node placement like
%      right=of A, below=of B
%    works out of the box without extra user configuration.
\ifAssignment@tikz
  \RequirePackage{tikz}
  \usetikzlibrary{calc,positioning,arrows.meta,intersections,decorations.pathreplacing,fit}

\fi

