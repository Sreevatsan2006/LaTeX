
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{Assignment}

% ============================================================================
% Assignment.sty
% Purpose:
% - One-stop package for assignment writing with:
%   1) document/layout defaults,
%   2) theorem/problem UI and framing,
%   3) a large personal math macro library.
%
% How to use (quick start):
%   \usepackage[palatino]{Assignment}
%   % optional:
%   % \AssignmentColorMode{color}
%
% Public high-level options:
% - Typography: classic | charter | palatino
% - Behavior: notikz | standardsections | nomacros | nolayout | notheoremui
%
% Compatibility:
% - Defaults preserve legacy behavior: all subsystems enabled.
% - Optional feature gates only disable side effects for users who opt out.
% ============================================================================

% ------------------------------
% Package Options
% ------------------------------
% Purpose:
% - Configure optional subsystems and fonts before loading dependencies.
%
% How to use:
%   \usepackage[palatino,notikz]{Assignment}
%   \usepackage[nomacros]{Assignment}
%
% Public options:
% - notikz         : skip TikZ and related presets
% - standardsections: keep default LaTeX starred section behavior
% - nomacros       : disable the large macro-library block
% - nolayout       : disable layout side effects (spacing/headers/section rewrites)
% - notheoremui    : disable theorem/problem environments, framed boxes, and
%                    pseudocode/algo wrappers

% `notikz`: Do not load TikZ. Useful for faster compiles if figures are unused.
\newif\ifAssignment@tikz
\Assignment@tikztrue
\DeclareOption{notikz}{\Assignment@tikzfalse}

% `standardsections`: Keep vanilla behavior for \section* and \subsection*.
\newif\ifAssignment@standardsections
\Assignment@standardsectionsfalse
\DeclareOption{standardsections}{\Assignment@standardsectionstrue}

% Feature-gate options (all enabled by default for backward compatibility).
\newif\ifAssignment@macros
\Assignment@macrostrue
\DeclareOption{nomacros}{\Assignment@macrosfalse}

\newif\ifAssignment@layout
\Assignment@layouttrue
\DeclareOption{nolayout}{\Assignment@layoutfalse}

\newif\ifAssignment@theoremui
\Assignment@theoremuitrue
\DeclareOption{notheoremui}{\Assignment@theoremuifalse}

% Font options
% `classic`  -> default Computer Modern text look
% `charter`  -> Charter text
% `palatino` -> Palatino text (default)
\def\Assignment@font{palatino}
\DeclareOption{classic}{\def\Assignment@font{classic}}
\DeclareOption{charter}{\def\Assignment@font{charter}}
\DeclareOption{palatino}{\def\Assignment@font{palatino}}

\ProcessOptions\relax

% ------------------------------
% Dependency Policy
% ------------------------------
