% ------------------------------------------------------------------
% Color mode engine (user-facing customization layer)
% ------------------------------------------------------------------
% What this block controls:
% 1) Frame intensity (line widths + background tinting),
% 2) Heading accent colors (theorem/definition/etc. titles),
% 3) Link behavior/colors (internal/external/citation links).
%
% Supported modes: none (default), color.
% - none : keep typography/layout, remove visible framing and color accents.
% - color: enable color styling.
%
% Quick user usage in a .tex file:
%   \AssignmentColorMode{none}
%   \AssignmentColorMode{color}
%
% Compatibility note:
% - Legacy boolean aliases are also accepted:
%   true/false, on/off, 1/0
%
% Maintainer note:
% - If you add a new mode, update BOTH:
%   1) \Assignment@ApplyColorModeSettings (behavior),
%   2) \AssignmentColorMode command (mode parser below).
\def\Assignment@colormode{none}
% Framed-block appearance knobs:
% - \Assignment@CalloutBgMix: background blend strength (0 = white, 100 = full color)
% - \Assignment@GenericBoxTint: tint level used by generic/custom color boxes
% - \Assignment@MainLineWidth: line width for theorem/major framed blocks
% - \Assignment@CalloutLineWidth: line width for lightweight callout boxes
\def\Assignment@CalloutBgMix{0}
\def\Assignment@GenericBoxTint{0}
\def\Assignment@MainLineWidth{0pt}
\def\Assignment@CalloutLineWidth{0pt}
% Heading colors. These are reassigned per mode.
\def\Assignment@TheoremHeadColor{Ink}
\def\Assignment@StatementHeadColor{Ink}
\def\Assignment@DefinitionHeadColor{Ink}
\def\Assignment@AlgoTitleColor{Ink}



\providecommand{\Assignment@ApplyColorModeSettings}{%
  % Base palette for `color` mode.
  \def\Assignment@CalloutBgMix{100}%
  \def\Assignment@GenericBoxTint{9}%
  \def\Assignment@MainLineWidth{0.9pt}%
  \def\Assignment@CalloutLineWidth{0.9pt}%
  \def\Assignment@TheoremHeadColor{Cobalt}%
  \def\Assignment@StatementHeadColor{Violet}%
  \def\Assignment@DefinitionHeadColor{Orange}%
  \def\Assignment@AlgoTitleColor{Violet}%
  \ifdefstring{\Assignment@colormode}{none}{%
    % "none" = remove colors but keep spacing/layout stable.
    \def\Assignment@CalloutBgMix{0}%
    \def\Assignment@GenericBoxTint{0}%
    \def\Assignment@MainLineWidth{0pt}%
    \def\Assignment@CalloutLineWidth{0pt}%
    \def\Assignment@TheoremHeadColor{Ink}%
    \def\Assignment@StatementHeadColor{Ink}%
    \def\Assignment@DefinitionHeadColor{Ink}%
    \def\Assignment@AlgoTitleColor{Ink}%
  }{}%
}

\providecommand{\Assignment@ApplyLinkColors}{%
  \ifdefstring{\Assignment@colormode}{none}{%
    % Monochrome mode: suppress colored links.
    \hypersetup{hidelinks}%
  }{%
    % Color mode: keep links colored instead of boxed.
    \hypersetup{%
      colorlinks=true,
      linkcolor=Indigo,
      urlcolor=Violet,
      citecolor=Violet,
      filecolor=Violet,
      anchorcolor=Indigo
    }%
  }%
}




% Package startup styling.
% 1) Read the current color mode (none/color) and apply style values.
% 2) Apply hyperlink behavior/colors for the active mode.
% Users can always override link behavior in the document preamble, e.g.
%   \hypersetup{colorlinks=false}
\Assignment@ApplyColorModeSettings
\Assignment@ApplyLinkColors

% List and header defaults are layout-side effects. Keep them opt-out friendly.
\ifAssignment@layout
  % List spacing defaults:
  % - leftmargin=*  : align list body naturally with surrounding text width.
  % - itemsep/topsep: compact but readable.
  \setlist[itemize]{leftmargin=*, itemsep=0.15em, topsep=0.35em}
  \setlist[enumerate]{leftmargin=*, itemsep=0.15em, topsep=0.35em}

  % Running header/footer defaults for assignment sheets.
  % Left: user name, Center: course, Right: homework number, Footer: page.
  \pagestyle{fancy}
  \fancyhf{}
  \fancyhead[L]{\YourName}
  \fancyhead[C]{\CourseName}
  \fancyhead[R]{HW \AssignmentNumber}
  \fancyfoot[C]{\thepage}
\fi

\providecommand{\Assignment@DefineFramedStyles}{}

% ------------------------------
% Theorem/UI Subsystem (Optional)
% ------------------------------
% Purpose:
% - Provide theorem/problem environments, statement framing styles, and
%   lightweight boxed UI helpers (`cbox`, `ColorBox`, `pseudocode`, `algo`).
%
% How to use:
% - Enabled by default.
% - Disable this entire subsystem with:
%     \usepackage[notheoremui]{Assignment}
%
% Public commands/environments:
% - Theorem family: theorem, lemma, proposition, corollary
% - Support family: fact, property, conjecture, question, statement, obs
% - Definition family: definition, example, remark
% - Problem/Solution: problem, chosenproblem, solution, problembox styling
% - Box helpers: ColorNoteBox, cbox, ColorBox, pseudocode, algo
%
% Compatibility notes:
% - If an environment already exists in the host document, this package does
%   not redefine it (collision-safe theorem declarations).
% - When disabled, color-mode commands still exist; framed-style refresh
%   becomes a no-op so \AssignmentColorMode remains safe to call.
% Theorem/UI helpers that should vanish under [notheoremui].
\ifAssignment@theoremui

% Theorem heading styles.
% These style names are intentionally descriptive (PascalCase) so users can
% quickly understand what they control and switch styles safely.
%
% \newtheoremstyle arguments in order:
% 1) Space above, 2) Space below, 3) Body font, 4) Indent,
% 5) Head font, 6) Punctuation after head, 7) Space after head, 8) Head spec.
%
% `TheoremHeader`: core result statements.
%   Used for theorem / lemma / proposition / corollary.
% `SupportHeader`: supporting statement-like results.
%   Used for fact / property / conjecture / question / statement / observation.
% `DefinitionHeader`: definition-style statements.
% Examples/remarks intentionally use built-in amsthm styles (no custom header).
\newtheoremstyle{TheoremHeader}
  {0.6em}{0.6em}{}{}{\bfseries\color{\Assignment@TheoremHeadColor}}{.}{0.6em}{}
\newtheoremstyle{SupportHeader}
  {0.6em}{0.6em}{}{}{\bfseries\color{\Assignment@StatementHeadColor}}{.}{0.6em}{}
\newtheoremstyle{DefinitionHeader}
  {0.6em}{0.6em}{}{}{\bfseries\color{\Assignment@DefinitionHeadColor}}{.}{0.6em}{}

% Theorem-family numbering map with collision-safe declarations.
%
% Goal:
% - If a document already defines an environment (for example `theorem`),
%   we will not redefine it.
% - Missing environments are added automatically.
%
% This behavior enables seamless drop-in usage on legacy files while still
% giving sensible defaults on fresh files.
\providecommand{\Assignment@MaybeNewTheoremBySection}[3]{%
  \ifcsdef{#1}{}{%
    \theoremstyle{#2}%
    \newtheorem{#1}{#3}[section]%
  }%
}
\providecommand{\Assignment@MaybeNewTheoremShared}[4]{%
  \ifcsdef{#1}{}{%
    \theoremstyle{#2}%
    \newtheorem{#1}[#3]{#4}%
  }%
}

% Core theorem family.
% - `theorem` resets by section.
% - lemma/proposition/corollary share theorem numbering.
\Assignment@MaybeNewTheoremBySection{theorem}{TheoremHeader}{Theorem}
\Assignment@MaybeNewTheoremShared{lemma}{TheoremHeader}{theorem}{Lemma}
\Assignment@MaybeNewTheoremShared{proposition}{TheoremHeader}{theorem}{Proposition}
\Assignment@MaybeNewTheoremShared{corollary}{TheoremHeader}{theorem}{Corollary}

% Support statement family.
% - `fact` resets by section.
% - related statement environments share `fact` numbering.
\Assignment@MaybeNewTheoremBySection{fact}{SupportHeader}{Fact}
\Assignment@MaybeNewTheoremShared{property}{SupportHeader}{fact}{Property}
\Assignment@MaybeNewTheoremShared{conjecture}{SupportHeader}{fact}{Conjecture}
\Assignment@MaybeNewTheoremShared{question}{SupportHeader}{fact}{Question}
\Assignment@MaybeNewTheoremShared{statement}{SupportHeader}{fact}{Statement}
\Assignment@MaybeNewTheoremShared{obs}{SupportHeader}{fact}{Observation}

% Definitions/examples/remarks keep independent section-based counters.
\Assignment@MaybeNewTheoremBySection{definition}{DefinitionHeader}{Definition}
\Assignment@MaybeNewTheoremBySection{example}{definition}{Example}
\Assignment@MaybeNewTheoremBySection{remark}{remark}{Remark}

% Problem/Solution pair (worksheet-style):
% - Heading format follows the requested online snippet.
% - `problem` is independent (not tied to theorem/fact counters).
% - `problem` normally increments by one, but an optional numeric first argument
%   makes that problem use the original sheet number:
%     \begin{problem}[7] ... \end{problem}
%     \begin{problem}[7][Optional note] ... \end{problem}
% - A nonnumeric optional argument keeps the usual amsthm note behavior:
%     \begin{problem}[Optional note] ... \end{problem}
% - \SetNextProblemNumber{7} remains available when a separate counter reset is clearer.
% - `chosenproblem` is kept as a readable compatibility alias.
% - `solution` draws a horizontal rule, then opens a proof-like block titled "Solution".
% - Inside `solution`, `parts` lists get room between answers automatically.
% - Ending a solution starts a new page by default. Override
%   \AssignmentSolutionPageBreak after loading the package if a project wants
%   continuous solutions.
\ifcsdef{th@problemstyle}{}{%
  \newtheoremstyle{problemstyle}
    {\topsep}{\topsep}{\normalfont}{}{}{.}{0.5em}{\bfseries #1\ #2\thmnote{ (#3)}}%
}

\ifcsdef{problem}{}{%
  \theoremstyle{problemstyle}%
  \newtheorem{problem}{Problem}%
}

\NewDocumentCommand{\SetNextProblemNumber}{m}{%
  \setcounter{problem}{\numexpr#1-1\relax}%
}

\ExplSyntaxOn
\cs_new_protected:cpn { Assignment@IfIntegerTF } #1#2#3
  {
    \regex_match:nnTF { \A [0-9]+ \Z } { #1 } { #2 } { #3 }
  }
\ExplSyntaxOff

\let\Assignment@baseproblem\problem
\let\Assignment@baseendproblem\endproblem
\RenewDocumentEnvironment{problem}{o o +b}{%
  \IfNoValueTF{#1}{%
    \Assignment@baseproblem#3\Assignment@baseendproblem%
  }{%
    \Assignment@IfIntegerTF{#1}{%
      \SetNextProblemNumber{#1}%
      \IfNoValueTF{#2}{%
        \Assignment@baseproblem#3\Assignment@baseendproblem%
      }{%
        \Assignment@baseproblem[#2]#3\Assignment@baseendproblem%
      }%
    }{%
      \Assignment@baseproblem[#1]#3\Assignment@baseendproblem%
    }%
  }%
}{}

\NewDocumentEnvironment{chosenproblem}{m O{} +b}{%
  \ifstrempty{#2}{%
    \begin{problem}[#1]#3\end{problem}%
  }{%
    \begin{problem}[#1][#2]#3\end{problem}%
  }%
}{}

\newlength{\AssignmentSolutionPartItemSep}
\setlength{\AssignmentSolutionPartItemSep}{0.8\baselineskip}
\newlength{\AssignmentSolutionNestedPartItemSep}
\setlength{\AssignmentSolutionNestedPartItemSep}{0.45\baselineskip}
\providecommand{\AssignmentSolutionPageBreak}{\newpage}
\providecommand{\Assignment@ApplySolutionPartSpacing}{%
  \setlist[parts,1]{label=(\alph*), ref=(\alph*), leftmargin=*, itemsep=\AssignmentSolutionPartItemSep, topsep=0.45\baselineskip, parsep=0pt}%
  \setlist[parts,2]{label=(\roman*), ref=(\roman*), leftmargin=*, itemsep=\AssignmentSolutionNestedPartItemSep, topsep=0.25\baselineskip, parsep=0pt}%
  \setlist[parts,3]{label=(\arabic*), ref=(\arabic*), leftmargin=*, itemsep=0.25\baselineskip, topsep=0.2\baselineskip, parsep=0pt}%
}

\ifcsdef{solution}{}{%
  \newenvironment{solution}{%
    \par\vspace{0.5\topsep}%
    \noindent\rule{\linewidth}{0.4pt}\par\nobreak\vspace{-2pt}%
    \begin{proof}[Solution]%
    \Assignment@ApplySolutionPartSpacing%
  }{%
    \end{proof}%
    \AssignmentSolutionPageBreak%
  }%
}

\providecommand{\Assignment@DefineUnframedStyle}[5]{%
  \mdfdefinestyle{#1}{%
    linecolor=white,
    linewidth=0pt,
    backgroundcolor=white,
    roundcorner=0pt,
    innertopmargin=#4,
    innerbottommargin=#4,
    innerleftmargin=#5,
    innerrightmargin=#5,
    skipabove=#2,
    skipbelow=#3,
    nobreak=true
  }%
}

\renewcommand{\Assignment@DefineFramedStyles}{%
  \ifdefstring{\Assignment@colormode}{none}{%
    \Assignment@DefineUnframedStyle{theorembox}{0.8em}{0.8em}{0.7em}{0.9em}%
    \Assignment@DefineUnframedStyle{definitionbox}{0.8em}{0.8em}{0.7em}{0.9em}%
    \Assignment@DefineUnframedStyle{problembox}{0.8em}{0.8em}{0.7em}{0.9em}%
    \Assignment@DefineUnframedStyle{algoboxstyle}{0.7em}{0.7em}{0.6em}{0.8em}%
  }{%
    % Core theorem-family wrappers.
    \mdfdefinestyle{theorembox}{%
      linecolor=Cobalt,
      linewidth=\Assignment@MainLineWidth,
      backgroundcolor=InfoBg!\Assignment@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.7em,
      innerbottommargin=0.7em,
      innerleftmargin=0.9em,
      innerrightmargin=0.9em,
      skipabove=0.8em,
      skipbelow=0.8em,
      nobreak=true
    }%
    \mdfdefinestyle{definitionbox}{%
      linecolor=Orange,
      linewidth=\Assignment@MainLineWidth,
      backgroundcolor=WarningBg!\Assignment@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.7em,
      innerbottommargin=0.7em,
      innerleftmargin=0.9em,
      innerrightmargin=0.9em,
      skipabove=0.8em,
      skipbelow=0.8em,
      nobreak=true
    }%
    % Problem statements are question-like: cool indigo frame + soft info tint.
    \mdfdefinestyle{problembox}{%
      linecolor=Indigo,
      linewidth=\Assignment@MainLineWidth,
      backgroundcolor=InfoBg!\Assignment@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.7em,
      innerbottommargin=0.7em,
      innerleftmargin=0.9em,
      innerrightmargin=0.9em,
      skipabove=0.8em,
      skipbelow=0.8em,
      nobreak=true
    }%
    % Keep algorithm box styling (AlgoColor support).
    \mdfdefinestyle{algoboxstyle}{%
      linecolor=Violet,
      linewidth=\Assignment@MainLineWidth,
      backgroundcolor=HighlightBg!\Assignment@CalloutBgMix,
      roundcorner=6pt,
      innertopmargin=0.6em,
      innerbottommargin=0.6em,
      innerleftmargin=0.8em,
      innerrightmargin=0.8em,
      skipabove=0.7em,
      skipbelow=0.7em,
      nobreak=true
    }%
  }%
}

% Apply frame definitions once at load time.
\Assignment@DefineFramedStyles

\fi

% Public color API
\NewDocumentCommand{\AssignmentColorMode}{m}{%
  \edef\Assignment@requestedmode{#1}%
  % Normalize user input so TRUE/True/true all behave the same.
  \lowercase{\edef\Assignment@requestedmode{\Assignment@requestedmode}}%
  \ifdefstring{\Assignment@requestedmode}{none}{%
    \def\Assignment@colormode{none}%
  }{%
    \ifdefstring{\Assignment@requestedmode}{false}{%
      \def\Assignment@colormode{none}%
    }{%
      \ifdefstring{\Assignment@requestedmode}{off}{%
        \def\Assignment@colormode{none}%
      }{%
        \ifdefstring{\Assignment@requestedmode}{0}{%
          \def\Assignment@colormode{none}%
        }{%
          \ifdefstring{\Assignment@requestedmode}{color}{%
            \def\Assignment@colormode{color}%
          }{%
            \ifdefstring{\Assignment@requestedmode}{true}{%
              \def\Assignment@colormode{color}%
            }{%
              \ifdefstring{\Assignment@requestedmode}{on}{%
                \def\Assignment@colormode{color}%
              }{%
                \ifdefstring{\Assignment@requestedmode}{1}{%
                  \def\Assignment@colormode{color}%
                }{%
                  \PackageWarning{Assignment}{Unknown color mode '#1'. Use 'none' or 'color'. Falling back to none}%
                  \def\Assignment@colormode{none}%
                }%
              }%
            }%
          }%
        }%
      }%
    }%
  }%
  \Assignment@ApplyColorModeSettings
  \Assignment@ApplyLinkColors
  \Assignment@DefineFramedStyles
}

% ------------------------------
% Compatibility Layer
% ------------------------------
% Purpose:
% - Preserve legacy command names while keeping a single canonical API.
%
% How to use:
% - Prefer \AssignmentColorMode{none|color} in new documents.
% - Legacy \MathColorMode{...} remains supported as an alias.
%
% Public compatibility commands:
% - \MathColorMode
%
% Compatibility notes:
% - Alias is intentionally strict pass-through to avoid drift.
% Compatibility alias for legacy docs/snippets that still call \MathColorMode.
\ifcsdef{MathColorMode}{%
  \RenewDocumentCommand{\MathColorMode}{m}{%
    \AssignmentColorMode{#1}%
  }%
}{%
  \NewDocumentCommand{\MathColorMode}{m}{%
    \AssignmentColorMode{#1}%
  }%
}


\ifAssignment@theoremui
\providecommand{\Assignment@BoxTitle}[1]{%
  \ifstrempty{#1}{}{{\textbf{\textcolor{Ink}{#1}}\par\smallskip}}%
}

% Generic color callout:
%   \begin{ColorNoteBox}{<ColorName>}[Optional Title] ... \end{ColorNoteBox}
% This is useful when a semantic box is not specific enough.
% `<ColorName>` must be an xcolor-known color.
\NewDocumentEnvironment{ColorNoteBox}{m O{} +b}{%
  \begin{mdframed}[
    linecolor=#1,
    linewidth=\Assignment@CalloutLineWidth,
    backgroundcolor=#1!\Assignment@GenericBoxTint,
    roundcorner=4pt,
    innertopmargin=0.45em,
    innerbottommargin=0.45em,
    innerleftmargin=0.65em,
    innerrightmargin=0.65em,
    skipabove=0.35em,
    skipbelow=0.35em,
    nobreak=true
  ]\Assignment@BoxTitle{#2}#3\end{mdframed}%
}{}

% Simple all-purpose colored box:
% Usage:
%   \begin{cbox}[Blue][Optional Title] ... \end{cbox}
% First optional argument = border/fill base color.
% Second optional argument = title line (leave empty for no title).
\NewDocumentEnvironment{cbox}{O{Blue} O{} +b}{%
  \begin{ColorNoteBox}{#1}[#2]#3\end{ColorNoteBox}%
}{}

% Readable alias (PascalCase). We avoid lowercase `box`/`colorbox` because
% those names collide with core TeX/xcolor commands.
\ifcsdef{ColorBox}{%
  \RenewDocumentEnvironment{ColorBox}{O{Blue} O{} +b}{%
    \begin{cbox}[#1][#2]#3\end{cbox}%
  }{}%
}{%
  \NewDocumentEnvironment{ColorBox}{O{Blue} O{} +b}{%
    \begin{cbox}[#1][#2]#3\end{cbox}%
  }{}%
}




% Lightweight algorithm wrapper.
% - This package DOES load `algorithm` + `algpseudocode` globally for users who
%   want numbered algorithm floats.
% - The `pseudocode`/`algo` environments below are intentionally independent
%   wrappers: they provide a simple boxed monospaced block without forcing float
%   usage or algorithmic keyword syntax.
% - `pseudocode` prints a titled framed block in monospaced text.
% - `algo` is a short alias with identical behavior.
% - No forced numbering, no forced keywords: write natural-language pseudocode.
\NewDocumentEnvironment{pseudocode}{O{Algorithm} +b}{%
  \begin{mdframed}[style=algoboxstyle]%
  {\textbf{\textcolor{\Assignment@AlgoTitleColor}{#1}}}\par\smallskip
  {\ttfamily\small #2}%
  \end{mdframed}%
}{}

\NewDocumentEnvironment{algo}{O{Algorithm} +b}{%
  \begin{pseudocode}[#1]#2\end{pseudocode}%
}{}


% Automatically wrap selected theorem-like environments
% This keeps source files clean: users just write \begin{theorem} ... \end{theorem}.
\surroundwithmdframed[style=theorembox]{theorem}
\surroundwithmdframed[style=theorembox]{lemma}
\surroundwithmdframed[style=theorembox]{proposition}
\surroundwithmdframed[style=theorembox]{corollary}
\surroundwithmdframed[style=definitionbox]{definition}
\surroundwithmdframed[style=problembox]{problem}

% Prevent awkward page breaks where a theorem title lands at page bottom.
% `Needspace` asks for a minimum vertical budget before starting each block.
\AtBeginEnvironment{theorem}{\Needspace{7\baselineskip}}
\AtBeginEnvironment{lemma}{\Needspace{7\baselineskip}}
\AtBeginEnvironment{proposition}{\Needspace{7\baselineskip}}
\AtBeginEnvironment{corollary}{\Needspace{7\baselineskip}}
\AtBeginEnvironment{definition}{\Needspace{7\baselineskip}}
\AtBeginEnvironment{problem}{\Needspace{7\baselineskip}}
\AtBeginEnvironment{example}{\Needspace{6\baselineskip}}
\AtBeginEnvironment{remark}{\Needspace{6\baselineskip}}
\fi

% Multi-level parts list used in assignment questions.
% How to use:
%   \begin{parts}
%     \item ...
%     \begin{parts}
%       \item ...
%     \end{parts}
%   \end{parts}
\newlist{parts}{enumerate}{3}
\setlist[parts,1]{label=(\alph*), ref=(\alph*), leftmargin=*, itemsep=2pt, topsep=4pt}
\setlist[parts,2]{label=(\roman*), ref=(\roman*), leftmargin=*, itemsep=2pt, topsep=2pt}
\setlist[parts,3]{label=(\arabic*), ref=(\arabic*), leftmargin=*, itemsep=1pt, topsep=1pt}

