% Public commands touched:
% - \section
% - \subsection
%
% Compatibility notes:
% - Numbering/ToC behavior only changes for starred forms.
% Default behavior in this template:
% - \section* and \subsection* still advance counters.
% - They are included in the table of contents.
% - Section-based theorem numbering stays consistent even with starred headings.
%
% This is convenient for notes with titled blocks that you still want numbered.
% If you prefer vanilla LaTeX starred behavior (unnumbered + no ToC entry),
% load the package with option [standardsections].
% If `nolayout` is set, this override block is skipped entirely.
\ifAssignment@layout
\ifAssignment@standardsections\else
  \let\Assignment@orig@section\section
  \RenewDocumentCommand{\section}{s o m}{%
    \IfBooleanTF{#1}{%
      \refstepcounter{section}%
      \IfNoValueTF{#2}{%
        \Assignment@orig@section*{#3}%
        \addcontentsline{toc}{section}{\thesection\quad #3}%
      }{%
        \Assignment@orig@section*{#3}%
        \addcontentsline{toc}{section}{\thesection\quad #2}%
      }%
      \sectionmark{#3}%
    }{%
      \IfNoValueTF{#2}{\Assignment@orig@section{#3}}{\Assignment@orig@section[#2]{#3}}%
    }%
  }

  \let\Assignment@orig@subsection\subsection
  \RenewDocumentCommand{\subsection}{s o m}{%
    \IfBooleanTF{#1}{%
      \refstepcounter{subsection}%
      \IfNoValueTF{#2}{%
        \Assignment@orig@subsection*{#3}%
        \addcontentsline{toc}{subsection}{\thesubsection\quad #3}%
      }{%
        \Assignment@orig@subsection*{#3}%
        \addcontentsline{toc}{subsection}{\thesubsection\quad #2}%
      }%
    }{%
      \IfNoValueTF{#2}{\Assignment@orig@subsection{#3}}{\Assignment@orig@subsection[#2]{#3}}%
    }%
  }
\fi
\fi
