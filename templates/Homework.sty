  \colorlet{hwalgobg}{#2}%
  \colorlet{hwalgotitle}{#3}%
}

\newcommand{\hw@algocodefont}{\small}
\newcommand{\hw@setcodestyle}[1]{%
  \hw@ifstrequal{#1}{tiny}{%
    \renewcommand{\hw@algocodefont}{\tiny}%
  }{%
    \hw@ifstrequal{#1}{scriptsize}{%
      \renewcommand{\hw@algocodefont}{\scriptsize}%
    }{%
      \hw@ifstrequal{#1}{footnotesize}{%
        \renewcommand{\hw@algocodefont}{\footnotesize}%
      }{%
        \hw@ifstrequal{#1}{small}{%
          \renewcommand{\hw@algocodefont}{\small}%
        }{%
          \hw@ifstrequal{#1}{normalsize}{%
            \renewcommand{\hw@algocodefont}{\normalsize}%
          }{%
            \PackageWarning{Homework}{Unknown codestyle '#1'; using small}%
            \renewcommand{\hw@algocodefont}{\small}%
          }%
        }%
      }%
    }%
  }%
}
\hw@setcodestyle{\hw@codestyle}
\NewDocumentCommand{\SetCodeStyle}{m}{\hw@setcodestyle{#1}}

\newcommand{\AlgResetIndent}{\global\hw@algoindentlevel=0\relax}
\newcommand{\AlgIndent}{\global\advance\hw@algoindentlevel by 1\relax}
\newcommand{\AlgDedent}{\ifnum\hw@algoindentlevel>0\global\advance\hw@algoindentlevel by -1\relax\fi}
\let\Indent\AlgIndent
\let\Dedent\AlgDedent
\newcommand{\hw@algotab}{\hspace*{\dimexpr\hw@algoindentlevel\hw@algoindentstep\relax}}
\newcommand{\algokey}[1]{\textcolor{hwaccent}{#1}}
\NewDocumentCommand{\Kw}{m}{\algokey{#1}}
\NewDocumentCommand{\AlgLine}{m}{\noindent\hw@algotab#1\par}
\NewDocumentCommand{\Step}{m}{\AlgLine{#1}}
\NewDocumentCommand{\State}{m}{\Step{#1}}
\NewDocumentEnvironment{algblock}{m}{\Step{#1}\Indent}{\Dedent}
\NewDocumentEnvironment{AlgBlock}{m}{\begin{algblock}{#1}}{\end{algblock}}
\newcommand{\AlgoInput}[1]{\AlgLine{\algokey{Input:} #1}}
\newcommand{\AlgoOutput}[1]{\AlgLine{\algokey{Output:} #1}}
\newcommand{\AlgoInit}[1]{\AlgLine{\algokey{Initialize:} #1}}
\newcommand{\AlgoNote}[1]{\AlgLine{\textcolor{hwprimary}{\emph{#1}}}}
\NewDocumentCommand{\AlgIn}{m}{\AlgoInput{#1}}
\NewDocumentCommand{\AlgOut}{m}{\AlgoOutput{#1}}
\NewDocumentCommand{\AlgInit}{m}{\AlgoInit{#1}}
\NewDocumentCommand{\AlgNoteText}{m}{\AlgoNote{#1}}
\newif\ifhw@warnedpseudosteps
\hw@warnedpseudostepsfalse
\NewDocumentEnvironment{pseudosteps}{}{%
  \ifhw@warnedpseudosteps\else
    \PackageWarningNoLine{Homework}{pseudosteps is legacy; prefer \string\Step with \string\Indent/\string\Dedent}%
    \global\hw@warnedpseudostepstrue
  \fi
  \begin{list}{}{%
    \leftmargin=0pt
    \rightmargin=0pt
    \labelwidth=0pt
    \labelsep=0pt
    \itemindent=0pt
    \listparindent=0pt
    \itemsep=\hw@algostepsitemsep
    \topsep=\hw@algostepstopsep
    \parsep=\hw@algostepsparsep
    \partopsep=0pt
  }%
  \let\hw@ps@item\item
  \renewcommand{\item}{\hw@ps@item[]\hspace*{\dimexpr\hw@algoindentlevel\hw@algoindentstep\relax}}%
}{%
  \end{list}
}

\NewDocumentEnvironment{pseudocode}{O{Algorithm} +b}{%
  \Needspace{8\baselineskip}
  \par\addvspace{0.7\baselineskip}
  \begingroup
  \AlgResetIndent
  \ifhw@hasmdframed
    \begin{mdframed}[
      linecolor=hwalgoframe,
      backgroundcolor=hwalgobg,
      linewidth=\hwalgoboxrule,
      roundcorner=2pt,
      innerleftmargin=\hwalgoboxsep,
      innerrightmargin=\hwalgoboxsep,
      innertopmargin=\hwalgoboxsep,
      innerbottommargin=\hwalgoboxsep,
      skipabove=0pt,
      skipbelow=0pt
    ]
      \noindent\textcolor{hwalgotitle}{\textbf{#1}}\par
      \smallskip
      \noindent\textcolor{hwalgoframe}{\rule{\linewidth}{0.6pt}}\par
      \smallskip
      {\hw@algocodefont\ttfamily\raggedright\setlength{\parindent}{0pt}\setlength{\parskip}{\hw@algostepsitemsep}#2\par}
    \end{mdframed}
  \else
    \noindent\fcolorbox{hwalgoframe}{hwalgobg}{%
      \begin{minipage}{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}
        \noindent\textcolor{hwalgotitle}{\textbf{#1}}\par
        \smallskip
        \noindent\textcolor{hwalgoframe}{\rule{\linewidth}{0.6pt}}\par
        \smallskip
        {\hw@algocodefont\ttfamily\raggedright\setlength{\parindent}{0pt}\setlength{\parskip}{\hw@algostepsitemsep}#2\par}
      \end{minipage}%
    }%
  \fi
  \endgroup
  \addvspace{\hw@blockgap}
}{}

\NewDocumentEnvironment{algo}{O{Algorithm} +b}{\begin{pseudocode}[#1]#2\end{pseudocode}}{}

