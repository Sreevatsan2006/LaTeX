% --------------------------------------------------
% Hyperref and references
% --------------------------------------------------
\newcommand{\hw@linkmodevalue}{\hw@linkmode}
\newcommand{\hw@applyhyperrefstyle}{%
  \hw@ifstrequal{\hw@linkmodevalue}{auto}{%
    \ifhw@colorlinks
      \hypersetup{colorlinks=true,linkcolor=\hw@linkcolor,urlcolor=\hw@urlcolor,citecolor=\hw@citecolor}%
    \else
      \hypersetup{hidelinks}%
    \fi
  }{%
    \hw@ifstrequal{\hw@linkmodevalue}{color}{%
      \hypersetup{colorlinks=true,linkcolor=\hw@linkcolor,urlcolor=\hw@urlcolor,citecolor=\hw@citecolor}%
    }{%
      \hw@ifstrequal{\hw@linkmodevalue}{black}{%
        \hypersetup{colorlinks=true,linkcolor=black,urlcolor=black,citecolor=black}%
      }{%
        \hw@ifstrequal{\hw@linkmodevalue}{hide}{%
          \hypersetup{hidelinks}%
        }{%
          \hw@ifstrequal{\hw@linkmodevalue}{hidelinks}{%
            \hypersetup{hidelinks}%
          }{%
            \PackageWarning{Homework}{Unknown linkmode '\hw@linkmodevalue'; using hidelinks}%
            \hypersetup{hidelinks}%
          }%
        }%
      }%
    }%
  }%
}
\newcommand{\SetHomeworkLinkMode}[1]{%
  \renewcommand{\hw@linkmodevalue}{#1}%
  \hw@applyhyperrefstyle
}
\newcommand{\SetHomeworkLinkColors}[3]{%
  \renewcommand{\hw@linkcolor}{#1}%
  \renewcommand{\hw@urlcolor}{#2}%
  \renewcommand{\hw@citecolor}{#3}%
  \hw@applyhyperrefstyle
}
\hw@applyhyperrefstyle

