\NewDocumentEnvironment{solution}{O{Solution} +b}{%
  \ifhw@solutionsvisible
    \Needspace{7\baselineskip}
    \par\addvspace{\hwsolutionsep}%
    \hw@separatorline
    \smallskip\noindent\textbf{#1}\par\smallskip
    #2
    \par\addvspace{\hw@blockgap}
  \fi
}{}

\NewDocumentEnvironment{finalanswer}{+b}{%
  \par\smallskip
