\newif\ifhw@questionboxopen
\hw@questionboxopenfalse
\newcommand{\hw@openquestionbox}{%
  \ifhw@hasmdframed
    \begin{mdframed}[
      linecolor=hwquestionframe,
      backgroundcolor=hwquestionbg,
      linewidth=\hwquestionboxrule,
      roundcorner=2pt,
      innerleftmargin=\hwquestionboxsep,
      innerrightmargin=\hwquestionboxsep,
      innertopmargin=\hwquestionboxsep,
      innerbottommargin=\hwquestionboxsep,
      skipabove=0pt,
      skipbelow=0pt
    ]
    \global\hw@questionboxopentrue
  \fi
  \ignorespaces
}
\newcommand{\hw@closequestionbox}{%
  \ifhw@questionboxopen
    \end{mdframed}
    \global\hw@questionboxopenfalse
  \fi
}

\newcounter{hw@problemcount}
\newcounter{problem}
\renewcommand{\theproblem}{\arabic{problem}}

\newcommand{\hw@problemdivider}{%
  \ifnum\value{hw@problemcount}>0
    \ifhw@questionnewpage
      \clearpage
    \else
      \par\addvspace{\hwproblemsep}%
      \hw@separatorline\smallskip
    \fi
  \fi
  \stepcounter{hw@problemcount}%
}

\AtBeginDocument{%
  \setcounter{hw@problemcount}{0}%
  \hwApplyHeader
  \linespread{\hw@linespreadfactor}\selectfont
  \ifhw@numberwithinsection
    \numberwithin{equation}{section}
    \@addtoreset{problem}{section}
    \renewcommand{\theproblem}{\thesection.\arabic{problem}}
  \fi
}

% --------------------------------------------------
% Problem, theorem, and solution environments
% --------------------------------------------------
\NewDocumentEnvironment{problem}{O{}}{%
  \hw@problemdivider
  \Needspace{8\baselineskip}
  \refstepcounter{problem}%
  \hw@openquestionbox
  \par\noindent\textbf{Problem \theproblem\ifstrempty{#1}{}{ (#1)}}\par
  \vspace{\hw@problemtitlegap}
}{%
  \hw@closequestionbox
  \par\addvspace{\hw@blockgap}
}

\NewDocumentEnvironment{problem*}{O{}}{%
  \hw@problemdivider
  \Needspace{8\baselineskip}
  \hw@openquestionbox
  \par\noindent\textbf{Problem\ifstrempty{#1}{}{ (#1)}}\par
  \vspace{\hw@problemtitlegap}
}{%
  \hw@closequestionbox
  \par\addvspace{\hw@blockgap}
}

\newtheoremstyle{hwplain}
  {\topsep}{\topsep}{\itshape}{} {\bfseries}{}{0.5em}
  {#1~#2\ifstrempty{#3}{}{ (#3)}}
\theoremstyle{hwplain}
\newtheorem{theorem}{Theorem}[problem]
\newtheorem{lemma}{Lemma}[problem]
\newtheorem{proposition}{Proposition}[problem]
\newtheorem{corollary}{Corollary}[problem]

\newtheoremstyle{hwdefinition}
  {\topsep}{\topsep}{\normalfont}{} {\bfseries}{}{0.5em}
  {#1~#2\ifstrempty{#3}{}{ (#3)}}
\theoremstyle{hwdefinition}
\newtheorem{definition}{Definition}[problem]
\newtheorem{remark}{Remark}[problem]

\AfterEndEnvironment{theorem}{\hw@postblockspace}
\AfterEndEnvironment{lemma}{\hw@postblockspace}
\AfterEndEnvironment{proposition}{\hw@postblockspace}
\AfterEndEnvironment{corollary}{\hw@postblockspace}
\AfterEndEnvironment{definition}{\hw@postblockspace}
\AfterEndEnvironment{remark}{\hw@postblockspace}
\AfterEndEnvironment{proof}{\hw@postblockspace}

