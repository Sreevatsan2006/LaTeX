\newcommand{\hw@ifstrequal}[4]{%
  \edef\hw@tmpa{#1}%
  \edef\hw@tmpb{#2}%
  \ifx\hw@tmpa\hw@tmpb
    #3%
  \else
    #4%
  \fi
}

\newcommand{\hw@loadtextfont}[1]{%
  \hw@ifstrequal{#1}{charter}{%
    \IfFileExists{charter.sty}{\RequirePackage{charter}}{}%
  }{%
    \hw@ifstrequal{#1}{tgschola}{%
      \IfFileExists{tgschola.sty}{\RequirePackage{tgschola}}{%
        \PackageWarning{Homework}{tgschola.sty not found; falling back to charter}%
        \IfFileExists{charter.sty}{\RequirePackage{charter}}{}%
      }%
    }{%
      \hw@ifstrequal{#1}{schola}{%
        \IfFileExists{tgschola.sty}{\RequirePackage{tgschola}}{%
          \PackageWarning{Homework}{tgschola.sty not found; falling back to charter}%
          \IfFileExists{charter.sty}{\RequirePackage{charter}}{}%
        }%
      }{%
        \hw@ifstrequal{#1}{lmodern}{%
          \IfFileExists{lmodern.sty}{\RequirePackage{lmodern}}{%
            \PackageWarning{Homework}{lmodern.sty not found; keeping current text font}%
          }%
        }{%
          \hw@ifstrequal{#1}{palatino}{%
            \IfFileExists{newpxtext.sty}{\RequirePackage{newpxtext}}{%
              \IfFileExists{mathpazo.sty}{\RequirePackage{mathpazo}}{%
                \PackageWarning{Homework}{No Palatino package found; keeping current text font}%
              }%
            }%
          }{%
            \hw@ifstrequal{#1}{times}{%
              \IfFileExists{newtxtext.sty}{\RequirePackage{newtxtext}}{%
                \IfFileExists{mathptmx.sty}{\RequirePackage{mathptmx}}{%
                  \PackageWarning{Homework}{No Times package found; keeping current text font}%
                }%
              }%
            }{%
              \hw@ifstrequal{#1}{cm}{%
                \renewcommand{\rmdefault}{cmr}%
              }{%
                \PackageWarning{Homework}{Unknown textfont '#1'; falling back to charter}%
                \IfFileExists{charter.sty}{\RequirePackage{charter}}{}%
              }%
            }%
          }%
        }%
      }%
    }%
  }%
}

\newcommand{\hw@loadmonofont}[1]{%
  \hw@ifstrequal{#1}{default}{}{%
    \hw@ifstrequal{#1}{inconsolata}{%
      \IfFileExists{inconsolata.sty}{\RequirePackage[scaled=0.95]{inconsolata}}{%
        \PackageWarning{Homework}{inconsolata.sty not found; keeping current monospaced font}%
      }%
    }{%
      \hw@ifstrequal{#1}{beramono}{%
        \IfFileExists{beramono.sty}{\RequirePackage[scaled]{beramono}}{%
          \PackageWarning{Homework}{beramono.sty not found; keeping current monospaced font}%
        }%
      }{%
        \hw@ifstrequal{#1}{lmtt}{%
          \renewcommand{\ttdefault}{lmtt}%
        }{%
          \PackageWarning{Homework}{Unknown monofont '#1'; keeping current monospaced font}%
        }%
      }%
    }%
  }%
}

\hw@loadtextfont{\hw@textfont}
\hw@loadmonofont{\hw@monofont}

